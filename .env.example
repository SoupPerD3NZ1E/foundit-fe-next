# Base URL of the Spring Boot backend (FOUNDIT_BE)
NEXT_PUBLIC_API_URL=http://localhost:8085

# STOMP / SockJS WebSocket endpoint (used in Phase 6 chat)
NEXT_PUBLIC_WS_URL=http://localhost:8085/ws
